VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_ROOT_DOMAIN=skeduley.com
# Set to your production domain (e.g. skeduley.com). Used to generate public booking URLs.
# Provider URLs will be: businessname.skeduley.com (requires *.skeduley.com wildcard DNS on Vercel)
# For local dev, set to: localhost:5173 (path-based URLs will be used instead)

# Supabase Edge Function Secrets (set via: supabase secrets set KEY=value)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...          # Subscription checkout + billing portal webhooks
# STRIPE_BOOKING_WEBHOOK_SECRET=whsec_...  # Booking checkout + refund webhooks
# APP_URL=https://app.skeduley.com         # Used by Edge Functions for redirects

# Stripe Plan Price IDs (Frontend)
VITE_STRIPE_STARTER_MONTHLY=
VITE_STRIPE_STARTER_QUARTERLY=
VITE_STRIPE_STARTER_BIANNUAL=
VITE_STRIPE_STARTER_ANNUAL=

VITE_STRIPE_PRO_MONTHLY=
VITE_STRIPE_PRO_QUARTERLY=
VITE_STRIPE_PRO_BIANNUAL=
VITE_STRIPE_PRO_ANNUAL=

VITE_STRIPE_BUSINESS_MONTHLY=
VITE_STRIPE_BUSINESS_QUARTERLY=
VITE_STRIPE_BUSINESS_BIANNUAL=
VITE_STRIPE_BUSINESS_ANNUAL=
